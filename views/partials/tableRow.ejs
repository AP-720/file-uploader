<tr>
	<td class="file-table-cell"><%= file.name %></td>
	<td class="file-table-cell"><%= file.uploadedAt.toLocaleString("en-GB", { timeZone: "UTC" })  %></td>
	<td class="file-table-cell"><%= formatFileSize(file.size) %></td>
	<td class="file-table-cell">
		<div class="button-container">
			<form action="/folder/delete/<%= folder.id %>" method="post">
				<button type="submit" class="delete-button" onclick="return confirm('Are you sure you want to delete this file?');">	<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trash-icon lucide-trash"><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>
			</form>
			<a href="">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-down-icon lucide-file-down"><path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"/><path d="M14 2v5a1 1 0 0 0 1 1h5"/><path d="M12 18v-6"/><path d="m9 15 3 3 3-3"/></svg>
			</a>
		</div>
	</td>
</tr>